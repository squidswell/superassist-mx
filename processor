<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SuperAssist MX — Schedule Processor</title>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
:root{--bg:#0f1117;--surface:#1a1d27;--surface2:#22263a;--border:rgba(255,255,255,0.08);--text:#f0f2f8;--muted:#8b90a8;--red:#ff4d4d;--red-bg:rgba(255,77,77,0.12);--amber:#f59e0b;--amber-bg:rgba(245,158,11,0.12);--green:#34d399;--green-bg:rgba(52,211,153,0.12);--blue:#60a5fa;--blue-bg:rgba(96,165,250,0.12);--purple:#a78bfa;--purple-bg:rgba(167,139,250,0.12)}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;font-size:14px;line-height:1.5;min-height:100vh;padding:20px}
.container{max-width:700px;margin:0 auto}
.header{padding:0 0 20px;border-bottom:0.5px solid var(--border);margin-bottom:24px}
.header h1{font-size:18px;font-weight:600}
.header p{font-size:12px;color:var(--muted);margin-top:4px}
.back{font-size:12px;color:var(--blue);text-decoration:none;display:inline-block;margin-bottom:12px}
.card{background:var(--surface);border:0.5px solid var(--border);border-radius:12px;padding:20px;margin-bottom:16px}
.card h2{font-size:13px;font-weight:600;margin-bottom:12px;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em}
.drop-zone{border:1.5px dashed rgba(96,165,250,0.3);border-radius:10px;padding:40px;text-align:center;cursor:pointer;transition:all 0.2s;background:rgba(96,165,250,0.03)}
.drop-zone:hover,.drop-zone.drag-over{border-color:var(--blue);background:var(--blue-bg)}
.drop-zone.has-file{border-color:var(--green);background:var(--green-bg)}
.drop-icon{font-size:32px;margin-bottom:10px}
.drop-label{font-size:13px;color:var(--muted)}
.drop-label span{color:var(--blue);cursor:pointer}
.drop-label.has-file{color:var(--green)}
input[type=file]{display:none}
.btn{border:none;border-radius:8px;padding:12px 20px;font-size:13px;font-weight:600;cursor:pointer;transition:opacity 0.15s;width:100%}
.btn:disabled{opacity:0.4;cursor:not-allowed}
.btn-primary{background:var(--blue);color:#fff}
.btn-success{background:var(--green);color:#0f1117}
.btn-danger{background:var(--red-bg);color:var(--red);border:0.5px solid rgba(255,77,77,0.3)}
.status{padding:12px 14px;border-radius:8px;font-size:12px;margin-bottom:12px;display:flex;align-items:center;gap:8px}
.status.info{background:var(--blue-bg);color:#93c5fd;border:0.5px solid rgba(96,165,250,0.2)}
.status.success{background:var(--green-bg);color:var(--green);border:0.5px solid rgba(52,211,153,0.2)}
.status.error{background:var(--red-bg);color:#fca5a5;border:0.5px solid rgba(255,77,77,0.2)}
.status.processing{background:var(--amber-bg);color:#fcd34d;border:0.5px solid rgba(245,158,11,0.2)}
.spinner{width:14px;height:14px;border:2px solid rgba(245,158,11,0.3);border-top-color:var(--amber);border-radius:50%;animation:spin 0.8s linear infinite;flex-shrink:0}
@keyframes spin{to{transform:rotate(360deg)}}
.flight-table{width:100%;border-collapse:collapse;font-size:12px}
.flight-table th{text-align:left;padding:8px 10px;font-size:10px;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;color:var(--muted);border-bottom:0.5px solid var(--border)}
.flight-table td{padding:9px 10px;border-bottom:0.5px solid rgba(255,255,255,0.04);vertical-align:middle}
.flight-table tr:last-child td{border-bottom:none}
.flight-table tr:hover td{background:rgba(255,255,255,0.02)}
.reg-kpi{color:var(--amber);font-weight:600}
.reg-omo{color:var(--green);font-weight:600}
.reg-isl{color:var(--red);font-weight:600}
.badge{font-size:10px;font-weight:600;padding:2px 7px;border-radius:20px}
.badge-vip{background:var(--purple-bg);color:var(--purple)}
.badge-dom{background:rgba(251,191,36,0.15);color:#fbbf24}
.badge-priv{background:var(--blue-bg);color:var(--blue)}
.badge-aog{background:var(--red-bg);color:var(--red)}
.ac-status{display:flex;gap:8px;flex-wrap:wrap;margin-top:8px}
.ac-pill{font-size:11px;padding:4px 10px;border-radius:20px;background:var(--surface2);border:0.5px solid var(--border)}
.ac-pill.aog{background:var(--red-bg);color:var(--red);border-color:rgba(255,77,77,0.3)}
.ac-pill.svc{background:var(--green-bg);color:var(--green);border-color:rgba(52,211,153,0.3)}
.sun-row{display:flex;gap:16px;font-size:12px;color:var(--muted);margin-top:8px}
.sun-row span{color:var(--text)}
.section-divider{font-size:10px;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;color:var(--muted);padding:8px 10px;background:var(--surface2);border-bottom:0.5px solid var(--border)}
.confirm-bar{display:flex;gap:10px;margin-top:8px}
.confirm-bar .btn{flex:1}
</style>
</head>
<body>
<div class="container">
  <a class="back" href="index.html">← Back to SuperAssist MX</a>
  <div class="header">
    <h1>Flight Schedule Processor</h1>
    <p>Upload a confirmed daily schedule PDF — Claude Opus 4 will extract the flights for your review before saving.</p>
  </div>

  <!-- Upload -->
  <div class="card">
    <h2>Upload schedule</h2>
    <div class="drop-zone" id="drop-zone" onclick="document.getElementById('file-input').click()">
      <div class="drop-icon">📄</div>
      <div class="drop-label" id="drop-label">Drop PDF here or <span>browse</span></div>
    </div>
    <input type="file" id="file-input" accept=".pdf">
    <br>
    <button class="btn btn-primary" id="process-btn" disabled onclick="processFile()">Extract flights with Opus 4</button>
  </div>

  <!-- Status -->
  <div id="status-area"></div>

  <!-- Results -->
  <div id="results-area" style="display:none">
    <div class="card">
      <h2>Extracted data — review before saving</h2>

      <!-- Sun info -->
      <div id="sun-display" style="margin-bottom:14px"></div>

      <!-- Aircraft status -->
      <div id="ac-status-display" style="margin-bottom:14px"></div>

      <!-- Flights table -->
      <table class="flight-table">
        <thead>
          <tr>
            <th>Aircraft</th>
            <th>Dep</th>
            <th>Arr</th>
            <th>Route</th>
            <th>Pax</th>
            <th>Crew</th>
            <th>Flags</th>
          </tr>
        </thead>
        <tbody id="flights-tbody"></tbody>
      </table>

      <div class="confirm-bar">
        <button class="btn btn-success" id="confirm-btn" onclick="confirmAndSave()">✓ Looks correct — save to database</button>
        <button class="btn btn-danger" onclick="resetAll()">✗ Cancel</button>
      </div>
    </div>
  </div>

  <!-- Done -->
  <div id="done-area" style="display:none">
    <div class="card">
      <div class="status success">✓ Flights saved successfully. <a href="index.html" style="color:var(--green);margin-left:6px">Return to app →</a></div>
    </div>
  </div>
</div>

<script>
const SUPABASE_URL = 'https://yxwmieurufwxzjlbklcp.supabase.co';
const SUPABASE_KEY = 'sb_publishable_LHg8Z4VlZ7z3O6owAtc4yw_L561b2HH';
const { createClient } = supabase;
const db = createClient(SUPABASE_URL, SUPABASE_KEY);

let selectedFile = null;
let extractedData = null;

// Known staff list for crew matching
const KNOWN_CREW = ['Alex','Rory','Cristian','Lepani','Tony','Vili','Peni','Seru'];

// Drop zone
const dropZone = document.getElementById('drop-zone');
const fileInput = document.getElementById('file-input');

dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
dropZone.addEventListener('drop', e => {
  e.preventDefault();
  dropZone.classList.remove('drag-over');
  const file = e.dataTransfer.files[0];
  if(file && file.type === 'application/pdf') setFile(file);
});

fileInput.addEventListener('change', e => {
  if(e.target.files[0]) setFile(e.target.files[0]);
});

function setFile(file){
  selectedFile = file;
  dropZone.classList.add('has-file');
  document.getElementById('drop-label').textContent = `✓ ${file.name}`;
  document.getElementById('drop-label').className = 'drop-label has-file';
  document.getElementById('process-btn').disabled = false;
}

function setStatus(msg, type='info'){
  const icons = {info:'ℹ️', success:'✓', error:'✗', processing:''};
  const spinner = type === 'processing' ? '<div class="spinner"></div>' : '';
  document.getElementById('status-area').innerHTML =
    `<div class="status ${type}">${spinner}<span>${msg}</span></div>`;
}

function clearStatus(){ document.getElementById('status-area').innerHTML = ''; }

async function processFile(){
  if(!selectedFile) return;
  document.getElementById('process-btn').disabled = true;
  document.getElementById('results-area').style.display = 'none';
  document.getElementById('done-area').style.display = 'none';
  setStatus('Reading PDF...', 'processing');

  try {
    // Convert PDF to base64
    const base64 = await new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => resolve(reader.result.split(',')[1]);
      reader.onerror = reject;
      reader.readAsDataURL(selectedFile);
    });

    setStatus('Sending to Claude Opus 4 for extraction...', 'processing');

    const systemPrompt = `You are a flight schedule parser for Kokomo Resorts aviation operations in Fiji.
Extract flight data from the provided PDF and return ONLY valid JSON, no other text.

STRICT RULES:
- NEVER include passenger names — privacy rule, no exceptions
- Aircraft registrations: DQ-KPI, DQ-OMO, DQ-ISL only
- Routes: "NAN → YAK" (departing Nadi) or "YAK → NAN" (returning to Nadi)
- Times: HH:MM format (e.g. "0800" becomes "08:00")
- Crew: extract only staff pilot/crew labels (e.g. "65 ALEX" → "Alex", "85 RORY" → "Rory"). Combine multiple crew as comma-separated string.
- transfer_type: scan each flight block for keywords: DOMESTIC, PRIVATE, PLANE TO PLANE, YACHT, or any VH- registration. Null if none.
- is_vip: true if "VIP FACIL BOOKED" or similar appears near that flight
- pax_count: count passenger rows per flight block (not names, just the count)
- Aircraft status: if a column shows OOO mark the aircraft as "serviceable", AOG mark as "aog", otherwise null (no change)
- sunrise/sunset: extract from document header if present

Return this exact JSON structure:
{
  "flight_date": "YYYY-MM-DD",
  "sunrise": "HH:MM or null",
  "sunset": "HH:MM or null",
  "aircraft_status": {
    "DQ-KPI": "serviceable|aog|mx|null",
    "DQ-OMO": "serviceable|aog|mx|null",
    "DQ-ISL": "serviceable|aog|mx|null"
  },
  "flights": [
    {
      "aircraft_registration": "DQ-KPI",
      "departure_time": "08:00",
      "arrival_time": "08:45",
      "route": "NAN → YAK",
      "pax_count": 8,
      "crew": "Rory, Cristian",
      "is_vip": true,
      "transfer_type": "DOMESTIC"
    }
  ]
}`;

    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-opus-4-5',
        max_tokens: 2000,
        system: systemPrompt,
        messages: [{
          role: 'user',
          content: [{
            type: 'document',
            source: { type: 'base64', media_type: 'application/pdf', data: base64 }
          }, {
            type: 'text',
            text: 'Extract all flight data from this confirmed daily schedule PDF. Return only JSON.'
          }]
        }]
      })
    });

    const data = await response.json();
    if(!data.content || !data.content[0]) throw new Error('No response from API');

    const text = data.content[0].text.replace(/```json|```/g, '').trim();
    extractedData = JSON.parse(text);

    clearStatus();
    renderResults(extractedData);

  } catch(e) {
    setStatus('Error: ' + e.message, 'error');
    document.getElementById('process-btn').disabled = false;
  }
}

function renderResults(data){
  // Sun info
  if(data.sunrise || data.sunset){
    document.getElementById('sun-display').innerHTML =
      `<div class="sun-row">☀️ Sunrise <span>${data.sunrise||'—'}</span>&nbsp;&nbsp;🌙 Sunset <span>${data.sunset||'—'}</span>&nbsp;&nbsp;📅 <span>${data.flight_date}</span></div>`;
  } else {
    document.getElementById('sun-display').innerHTML =
      `<div class="sun-row">📅 <span>${data.flight_date}</span></div>`;
  }

  // Aircraft status changes
  const statusChanges = Object.entries(data.aircraft_status||{}).filter(([,v])=>v&&v!=='null');
  if(statusChanges.length > 0){
    let html = '<div style="font-size:11px;color:var(--muted);margin-bottom:6px">Status changes:</div><div class="ac-status">';
    statusChanges.forEach(([reg, status]) => {
      const cls = status === 'aog' ? 'aog' : 'svc';
      const label = status === 'aog' ? 'AOG' : status === 'serviceable' ? 'Serviceable' : status;
      html += `<div class="ac-pill ${cls}">${reg} → ${label}</div>`;
    });
    html += '</div>';
    document.getElementById('ac-status-display').innerHTML = html;
  }

  // Flights table
  const tbody = document.getElementById('flights-tbody');
  tbody.innerHTML = '';

  if(!data.flights || data.flights.length === 0){
    tbody.innerHTML = '<tr><td colspan="7" style="color:var(--muted);font-style:italic;padding:16px 10px">No flights extracted</td></tr>';
  } else {
    // Group by aircraft
    const AC_ORDER = ['DQ-OMO','DQ-KPI','DQ-ISL'];
    const sorted = [...data.flights].sort((a,b) => {
      const ai = AC_ORDER.indexOf(a.aircraft_registration);
      const bi = AC_ORDER.indexOf(b.aircraft_registration);
      if(ai !== bi) return ai - bi;
      return (a.departure_time||'').localeCompare(b.departure_time||'');
    });

    let lastAC = null;
    sorted.forEach(f => {
      if(f.aircraft_registration !== lastAC){
        lastAC = f.aircraft_registration;
        const regClass = f.aircraft_registration === 'DQ-KPI' ? 'reg-kpi' :
                         f.aircraft_registration === 'DQ-OMO' ? 'reg-omo' : 'reg-isl';
        tbody.innerHTML += `<tr><td colspan="7" class="section-divider">${f.aircraft_registration}</td></tr>`;
      }
      const isDep = (f.route||'').startsWith('NAN');
      const emoji = isDep ? '🛫' : '🛬';
      const badges = [
        f.is_vip ? '<span class="badge badge-vip">VIP</span>' : '',
        f.transfer_type === 'DOMESTIC' ? '<span class="badge badge-dom">DOMESTIC</span>' : '',
        f.transfer_type === 'PRIVATE' ? '<span class="badge badge-priv">PRIVATE</span>' : '',
        f.transfer_type && !['DOMESTIC','PRIVATE'].includes(f.transfer_type) ? `<span class="badge badge-priv">${f.transfer_type}</span>` : ''
      ].filter(Boolean).join(' ');

      tbody.innerHTML += `<tr>
        <td></td>
        <td>${emoji} ${f.departure_time||'—'}</td>
        <td>${f.arrival_time||'—'}</td>
        <td style="color:var(--muted)">${f.route||'—'}</td>
        <td>${f.pax_count||0} pax</td>
        <td style="color:var(--muted)">${f.crew||'—'}</td>
        <td>${badges}</td>
      </tr>`;
    });
  }

  document.getElementById('results-area').style.display = 'block';
}

async function confirmAndSave(){
  if(!extractedData) return;
  document.getElementById('confirm-btn').disabled = true;
  setStatus('Saving to database...', 'processing');

  try {
    const date = extractedData.flight_date;

    // Delete existing flights for this date
    await db.from('flights').delete().eq('flight_date', date);

    // Insert new flights
    if(extractedData.flights && extractedData.flights.length > 0){
      const rows = extractedData.flights.map(f => ({
        aircraft_registration: f.aircraft_registration,
        flight_date: date,
        departure_time: f.departure_time,
        arrival_time: f.arrival_time,
        route: f.route,
        pax_count: f.pax_count || 0,
        crew: f.crew || null,
        is_vip: f.is_vip || false,
        transfer_type: f.transfer_type || null,
        status: 'scheduled'
      }));
      await db.from('flights').insert(rows);
    }

    // Update aircraft statuses where specified
    const statusChanges = Object.entries(extractedData.aircraft_status||{})
      .filter(([,v]) => v && v !== 'null');
    for(const [reg, status] of statusChanges){
      await db.from('aircraft').update({status, updated_at: new Date().toISOString()})
        .eq('registration', reg);
    }

    // Update sunrise/sunset in app if present
    // (stored as a reminder for now — Phase 4 will have a dedicated field)

    clearStatus();
    document.getElementById('results-area').style.display = 'none';
    document.getElementById('done-area').style.display = 'block';

  } catch(e) {
    setStatus('Save error: ' + e.message, 'error');
    document.getElementById('confirm-btn').disabled = false;
  }
}

function resetAll(){
  selectedFile = null;
  extractedData = null;
  dropZone.classList.remove('has-file', 'drag-over');
  document.getElementById('drop-label').textContent = 'Drop PDF here or ';
  document.getElementById('drop-label').className = 'drop-label';
  document.getElementById('drop-label').innerHTML = 'Drop PDF here or <span>browse</span>';
  document.getElementById('process-btn').disabled = true;
  document.getElementById('results-area').style.display = 'none';
  document.getElementById('done-area').style.display = 'none';
  document.getElementById('status-area').innerHTML = '';
  fileInput.value = '';
}
</script>
</body>
</html>
